# Copy to configs/yolo_mps_experiment.env for local defaults.

export YOLO_USE_HOSTFILE=1
export YOLO_HOSTFILE=configs/hosts_macos_gpu
export YOLO_CORE_HOSTFILE=configs/hosts_macos_core
export YOLO_LIVE_HOSTFILE=configs/hosts_macos_live
export MPI_LAN_CIDR=192.168.31.0/24

export YOLO_NP=3
export YOLO_EVIDENCE_NP=3
export YOLO_P_LIST="1 2 3"
export YOLO_CORE_P_LIST="1 2 4 8 12"

export YOLO_SOURCE=data/classroom.mp4
export YOLO_MODEL=models/yolo11n.pt
export YOLO_MODEL_NAME=yolo11n.pt
export YOLO_DEVICE=mps
export YOLO_IMGSZ=512
export YOLO_CONF=0.35
export YOLO_IOU=0.50
export YOLO_TILE_GRID=1x1
export YOLO_OVERLAP=64
export YOLO_TILE_OWNER_FILTER=1
export YOLO_DEDUP_IOS=0.70
export YOLO_DEDUP_CENTER=0.30
export YOLO_DEDUP_AXIS_OVERLAP=0.70
export YOLO_DEDUP_GAP=0.08
export YOLO_DEDUP_NEAR_CAMERA=0
export YOLO_DEDUP_LARGE_AREA_RATIO=0.12
export YOLO_DEDUP_MERGE=1
export YOLO_SCHEDULE=static
export YOLO_CHUNK_SIZE=1
export YOLO_MASTER_COMPUTE=1
export YOLO_FRAME_WIDTH=1280
export YOLO_FRAME_HEIGHT=720

# Live camera mode: camera is opened only on the master rank. Worker ranks receive
# JPEG tiles over OpenMPI and run YOLO on their own Mac.
export YOLO_CAMERA_INDEX=0
export YOLO_LIVE_FRAMES=100
export YOLO_LIVE_VIEW=1
export YOLO_LIVE_MASTER_COMPUTE=1
export YOLO_LIVE_ANCHOR_FULL_FRAME=0
export YOLO_LIVE_TEMPORAL_DEDUP=0
export YOLO_LIVE_TEMPORAL_CENTER=0.55
export YOLO_LIVE_TEMPORAL_IOS=0.35
export YOLO_LIVE_IMGSZ=416
export YOLO_LIVE_TILE_GRID=3x1
export YOLO_LIVE_OVERLAP=64
export YOLO_LIVE_FPS=0
export YOLO_JPEG_QUALITY=80
export YOLO_CAMERA_SCRIPT=scripts/camera_tile_source.py
export YOLO_VIEWER_SCRIPT=scripts/live_viewer.py
# Optional test mode: use a video file as if it were the master camera.
export YOLO_LIVE_VIDEO_SOURCE=

# Required parallel implementation is C++17/OpenMPI.
# Use yolo for real inference, mock for buildable benchmarks, or command for debugging.
export YOLO_DETECTOR=yolo
export YOLO_DETECTOR_COMMAND=
export YOLO_WORKER_SCRIPT=scripts/yolo_worker.py
export YOLO_CPU_FALLBACK=1
export YOLO_AUTO_DOWNLOAD=1
export YOLO_SLEEP_MS=0

export YOLO_DEMO_FRAMES=20
export YOLO_PERF_FRAMES=100
export YOLO_FIND_FRAME_LIST="50 100 200 400 600 800"
export YOLO_TARGET_MIN_MS=120000
export YOLO_TARGET_MAX_MS=180000
