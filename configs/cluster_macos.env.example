# Copy to configs/cluster_macos.env and edit on the macOS master host.
# Do not commit configs/cluster_macos.env.

MASTER_HOST=master
NODE1_HOST=node1
NODE2_HOST=node2

MASTER_IP=192.168.31.159
NODE1_IP=192.168.31.138
NODE2_IP=192.168.31.208

# Keep this aligned with the LAN used by OpenMPI.
MPI_LAN_CIDR=192.168.31.0/24
# Homebrew OpenMPI path on macOS hosts. This makes remote prted lookup stable.
MPI_PREFIX=/opt/homebrew/opt/open-mpi
# Required for mixed MacBook/macOS host identities in OpenMPI 5/PRRTE.
MPI_HETERO_NODES=1
MPI_MAP_BY=node:OVERSUBSCRIBE

# macOS usernames for SSH. Change these per machine.
MASTER_USER=your_master_user
NODE1_USER=your_node1_user
NODE2_USER=your_node2_user

SLOTS_PER_NODE=4
# Use the same absolute path on all three Macs. /Users/Shared avoids problems
# when the three macOS usernames are different.
REMOTE_REPO_DIR=/Users/Shared/yolo-mpi-people-count
